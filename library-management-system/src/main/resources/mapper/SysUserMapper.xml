<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" 
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.SysUserMapper">
    <select id="selectByUsername" resultType="com.library.entity.SysUser">
        SELECT * FROM sys_user WHERE username = #{username}
    </select>
    <select id="selectById" resultType="com.library.entity.SysUser">
        SELECT * FROM sys_user WHERE id = #{id}
    </select>
    <insert id="insert" parameterType="com.library.entity.SysUser">
        INSERT INTO sys_user (username, password, role, create_time)
        VALUES (#{username}, #{password}, #{role}, #{createTime})
    </insert>
    <update id="update" parameterType="com.library.entity.SysUser">
        UPDATE sys_user SET username = #{username}, password = #{password}, 
               role = #{role} WHERE id = #{id}
    </update>
    <delete id="deleteById">
        DELETE FROM sys_user WHERE id = #{id}
    </delete>
</mapper>
