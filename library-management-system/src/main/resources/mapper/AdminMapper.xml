<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.AdminMapper">
    <resultMap id="BaseResultMap" type="com.library.entity.Admin">
        <id column="id" property="id"/>
        <result column="username" property="username"/>
        <result column="password" property="password"/>
        <result column="adminType" property="adminType"/>
    </resultMap>

    <select id="selectByUsername" resultMap="BaseResultMap">
        SELECT * FROM admin WHERE username = #{username}
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM admin WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM admin
    </select>

    <insert id="insert" parameterType="com.library.entity.Admin" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO admin (username, password, adminType)
        VALUES (#{username}, #{password}, #{adminType})
    </insert>

    <update id="updateById" parameterType="com.library.entity.Admin">
        UPDATE admin
        SET username = #{username},
            password = #{password},
            adminType = #{adminType}
        WHERE id = #{id}
    </update>
</mapper>