<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.LibraryCardMapper">
    <resultMap id="BaseResultMap" type="com.library.entity.LibraryCard">
        <id column="cardNo" property="cardNo"/>
        <result column="sno" property="sno"/>
        <result column="sname" property="sname"/>
        <result column="type" property="type"/>
        <result column="collage" property="collage"/>
        <result column="major" property="major"/>
        <result column="birth" property="birth"/>
        <result column="originPlace" property="originPlace"/>
        <result column="cardStatus" property="cardStatus"/>
        <result column="times" property="times"/>
        <result column="password" property="password"/>
    </resultMap>

    <select id="selectByCardNo" resultMap="BaseResultMap">
        SELECT * FROM libcard WHERE cardNo = #{cardNo}
    </select>

    <select id="selectBySno" resultMap="BaseResultMap">
        SELECT * FROM libcard WHERE sno = #{sno}
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM libcard WHERE cardStatus = #{status}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM libcard
    </select>

    <select id="searchByKeyword" resultMap="BaseResultMap">
        SELECT * FROM libcard
        WHERE cardNo LIKE CONCAT('%', #{keyword}, '%')
           OR sname LIKE CONCAT('%', #{keyword}, '%')
    </select>

    <insert id="insert" parameterType="com.library.entity.LibraryCard">
        INSERT INTO libcard (cardNo, sno, sname, type, collage, major, birth, originPlace, cardStatus, times, password)
        VALUES (#{cardNo}, #{sno}, #{sname}, #{type}, #{collage}, #{major}, #{birth}, #{originPlace}, #{cardStatus}, #{times}, #{password})
    </insert>

    <update id="updateByCardNo" parameterType="com.library.entity.LibraryCard">
        UPDATE libcard
        SET sno = #{sno},
            sname = #{sname},
            type = #{type},
            collage = #{collage},
            major = #{major},
            birth = #{birth},
            originPlace = #{originPlace},
            cardStatus = #{cardStatus},
            times = #{times},
            password = #{password}
        WHERE cardNo = #{cardNo}
    </update>
</mapper>