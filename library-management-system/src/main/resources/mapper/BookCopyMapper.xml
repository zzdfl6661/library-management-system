<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.library.mapper.BookCopyMapper">
    <resultMap id="BaseResultMap" type="com.library.entity.BookCopy">
        <id column="barCode" property="barCode"/>
        <result column="ISBN" property="ISBN"/>
        <result column="place" property="place"/>
        <result column="status" property="status"/>
        <result column="oldStatus" property="oldStatus"/>
    </resultMap>

    <select id="selectByBarCode" resultMap="BaseResultMap">
        SELECT * FROM bookcopy WHERE barCode = #{barCode}
    </select>

    <select id="selectByIsbn" resultMap="BaseResultMap">
        SELECT * FROM bookcopy WHERE ISBN = #{ISBN}
    </select>

    <select id="selectByIsbnAndStatus" resultMap="BaseResultMap">
        SELECT * FROM bookcopy WHERE ISBN = #{ISBN} AND status = #{status}
    </select>

    <select id="selectAvailableByIsbn" resultMap="BaseResultMap">
        SELECT * FROM bookcopy WHERE ISBN = #{ISBN} AND status = 1
    </select>

    <insert id="insert" parameterType="com.library.entity.BookCopy">
        INSERT INTO bookcopy (barCode, ISBN, place, status, oldStatus)
        VALUES (#{barCode}, #{ISBN}, #{place}, #{status.code}, #{oldStatus})
    </insert>

    <update id="updateByBarCode" parameterType="com.library.entity.BookCopy">
        UPDATE bookcopy
        SET ISBN = #{ISBN},
            place = #{place},
            status = #{status.code},
            oldStatus = #{oldStatus}
        WHERE barCode = #{barCode}
    </update>
</mapper>